{
  "enabledPlugins": {
    "fe-ai-tools@fe-vibe": true,
    "fe-databricks-tools@fe-vibe": true,
    "fe-file-expenses@fe-vibe": true,
    "fe-google-tools@fe-vibe": true,
    "fe-internal-tools@fe-vibe": true,
    "fe-jira-tools@fe-vibe": true,
    "fe-mcp-servers@fe-vibe": true,
    "fe-salesforce-tools@fe-vibe": true,
    "fe-specialized-agents@fe-vibe": true,
    "fe-vibe-setup@fe-vibe": true,
    "fe-workflows@fe-vibe": true,
    "plugin-builder@experimental-plugin-marketplace": true
  },
  "env": {
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "MAX_THINKING_TOKENS": "63999",
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "400000",
    "DISABLE_AUTOUPDATER": "1"
  },
  "showThinkingSummaries": true,
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "bash /Users/huong.vu/.vibe/marketplace/plugins/fe-vibe-setup/resources/hooks/mcp-auth-checker.sh",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "mcp__.*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "bash /Users/huong.vu/.vibe/marketplace/plugins/fe-vibe-setup/resources/hooks/mcp-stop-guard.sh",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "model": "opus",
  "sandbox": {
    "filesystem": {
      "allowWrite": [
        "~/.cache/uv"
      ]
    }
  }
}